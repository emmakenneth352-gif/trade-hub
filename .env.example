NODE_ENV=development
PORT=3000
DATABASE=mongodb://127.0.0.1:27017/tradehub

# JWT (optional in dev — auto defaults)
JWT_SECRET=tradehub-local-dev-secret-key-min-32-chars

# NelloByte VTU — https://www.nellobytesystems.com
# Copy this file to .env and fill in your credentials
NELLOBYTE_USER_ID=CK101255629
NELLOBYTE_API_KEY=your_apikey_here
NELLOBYTE_CALLBACK_URL=http://localhost:3000/api/v1/vtu/callback

# Cloudinary — https://cloudinary.com
CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@pgui4iwu
# Or use separate vars:
# CLOUDINARY_CLOUD_NAME=pgui4iwu
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Brevo (Bravo) — OTP / transactional email — https://app.brevo.com
# Verify a sender email in Brevo → Senders before going live
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your-verified-sender@yourdomain.com
BREVO_SENDER_NAME=Trade Hub
